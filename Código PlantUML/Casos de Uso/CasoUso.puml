@startuml

left to right direction

actor "Participante" as P
actor "Administrador" as A

rectangle "FlaBolão" {

  usecase "UC-01 - Cadastrar Participante" as UC01
  usecase "UC-02 - Realizar Login" as UC02
  usecase "UC-03 - Gerenciar Participantes" as UC03
  usecase "UC-04 - Cadastrar Jogo" as UC04
  usecase "UC-05 - Editar / Cancelar Jogo" as UC05
  usecase "UC-06 - Visualizar Jogos Disponíveis" as UC06
  usecase "UC-07 - Gerenciar Bolões" as UC07
  usecase "UC-08 - Registrar Palpite" as UC08
  usecase "UC-09 - Alterar Palpite" as UC09
  usecase "UC-10 - Consultar Histórico de Palpites" as UC10
  usecase "UC-11 - Registrar Resultado da Partida" as UC11
  usecase "UC-12 - Atualizar Pontuação e Ranking" as UC12
  usecase "UC-13 - Consultar Ranking" as UC13
  usecase "UC-14 - Visualizar Notificações" as UC14

}

' Participante
P --> UC01
P --> UC02
P --> UC06
P --> UC08
P --> UC09
P --> UC10
P --> UC13
P --> UC14

' Administrador
A --> UC02
A --> UC03
A --> UC04
A --> UC05
A --> UC07
A --> UC11
A --> UC12

' Relacionamentos
UC11 ..> UC12 : <<include>>
UC12 ..> UC14 : <<include>>

@enduml